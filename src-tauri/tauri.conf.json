{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hour Mosaic",
  "version": "0.1.0",
  "identifier": "com.clawbuster.hour-mosaic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Hour Mosaic",
        "url": "index.html",
        "width": 500,
        "height": 500,
        "minWidth": 150,
        "minHeight": 150,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": false,
        "shadow": true
      },
      {
        "label": "history",
        "title": "Hour Mosaic — History",
        "url": "history.html",
        "width": 900,
        "height": 700,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": false
      },
      {
        "label": "settings",
        "title": "Hour Mosaic — Settings",
        "url": "settings.html",
        "width": 820,
        "height": 640,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
